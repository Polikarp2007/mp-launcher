<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="PoliCoLauncherApp.Views.RoutePageView">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="300"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- LOGO -->
        <Image Source="/Assets/logo.png"
               RenderOptions.BitmapInterpolationMode="HighQuality"
               Width="180" Height="47"
               HorizontalAlignment="Left" VerticalAlignment="Top"
               Margin="25,23,0,0" ZIndex="1000"
               PointerPressed="OnLogoPressed"
               Cursor="Hand"
               Grid.Column="0"/>

        <!-- PAGE TITLE -->
        <TextBlock Text="Which ROUTE???"
                   FontSize="24" FontWeight="Bold" Foreground="#000000"
                   HorizontalAlignment="Right" VerticalAlignment="Top"
                   Margin="0,25,25,0" Grid.Column="1"/>

        <!-- SEPARATOR LINE -->
        <Border Height="1" Background="#000000" VerticalAlignment="Top"
                Margin="25,82,25,0" Grid.ColumnSpan="2"/>

        <!-- CONTENT -->
        <StackPanel Grid.ColumnSpan="2" Margin="25,90,25,0" VerticalAlignment="Top" HorizontalAlignment="Left">
            <TextBlock Text="Select a route where you will play multiplayer"
                       FontSize="14" Foreground="#888888" Margin="0,0,0,15"/>
            <Button Classes="DashBtn" Height="40" Click="OnBackClick" Margin="0,0,0,20">
                <TextBlock Text="Back" Classes="DashText" FontSize="13"/>
            </Button>
            <Button Classes="DashBtn" Height="120" Margin="0,0,0,10" Click="OnRouteClick">
                <Panel>
                    <Image Source="/Assets/M200_Arad_Radna.png" Stretch="UniformToFill"/>
                    <Border Background="#AA000000" CornerRadius="15"/>
                    <TextBlock Text="PC | M200 Arad - Radna v1.3" Classes="DashText" FontSize="16"/>
                </Panel>
            </Button>
        </StackPanel>
    </Grid>
</UserControl>
