<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="PoliCoLauncherApp.Views.TrainSelectPageView">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="300"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- LOGO -->
        <Image Source="/Assets/logo.png"
               RenderOptions.BitmapInterpolationMode="HighQuality"
               Width="180" Height="47"
               HorizontalAlignment="Left" VerticalAlignment="Top"
               Margin="25,23,0,0" ZIndex="1000"
               PointerPressed="OnLogoPressed"
               Cursor="Hand"
               Grid.Column="0"/>

        <!-- PAGE TITLE -->
        <TextBlock Text="Connect to PC/MP"
                   FontSize="24" FontWeight="Bold" Foreground="#000000"
                   HorizontalAlignment="Right" VerticalAlignment="Top"
                   Margin="0,25,25,0" Grid.Column="1"/>

        <!-- SEPARATOR LINE -->
        <Border Height="1" Background="#000000" VerticalAlignment="Top"
                Margin="25,82,25,0" Grid.ColumnSpan="2"/>

        <!-- CONTENT -->
        <ScrollViewer Grid.ColumnSpan="2" Margin="25,90,25,50" VerticalAlignment="Stretch" HorizontalAlignment="Stretch">
            <StackPanel Spacing="15" Margin="0,0,25,0">

                <TextBlock Text="Select the parameters to connect to a multiplayer train."
                           FontSize="14" Foreground="#888888" Margin="0,0,0,20"/>

                <!-- 1. TRAIN NUMBER -->
                <TextBlock Text="1. Select train type and number." FontSize="15" Foreground="#000000" Margin="0,0,0,8" FontWeight="Bold"/>
                <StackPanel Orientation="Horizontal" Spacing="8" Margin="0,0,0,18" HorizontalAlignment="Left">
                    <ComboBox x:Name="TrainTypeCombo" Height="40" Width="75" Padding="10,8" FontSize="14" HorizontalContentAlignment="Center" HorizontalAlignment="Left">
                        <ComboBoxItem Content="R"/>
                        <ComboBoxItem Content="IR"/>
                        <ComboBoxItem Content="IRN"/>
                        <ComboBoxItem Content="IC"/>
                        <ComboBoxItem Content="RE"/>
                        <ComboBoxItem Content="RM"/>
                    </ComboBox>
                    <TextBox x:Name="TrainNumberInput"
                             Classes="NumericInput"
                             Height="40" Width="70" Padding="0" FontSize="14"
                             PlaceholderText="11500" MaxLength="5"
                             TextInput="OnTrainNumberTextInput"
                             HorizontalAlignment="Left"/>
                </StackPanel>

                <!-- 2. START STATION -->
                <TextBlock Text="2. Select start station." FontSize="15" Foreground="#000000" Margin="0,0,0,8" FontWeight="Bold"/>
                <ComboBox x:Name="StartStationCombo" Height="40" Width="300" Margin="0,0,0,18" Padding="10,8" FontSize="14"
                          SelectionChanged="OnStartStationChanged" HorizontalAlignment="Left" HorizontalContentAlignment="Center">
                    <ComboBoxItem Content="Arad"/>
                    <ComboBoxItem Content="Radna"/>
                </ComboBox>

                <!-- 3. END STATION -->
                <TextBlock Text="3. Select end station." FontSize="15" Foreground="#000000" Margin="0,0,0,8" FontWeight="Bold"/>
                <ComboBox x:Name="EndStationCombo" Height="40" Width="300" Margin="0,0,0,18" Padding="10,8" FontSize="14"
                          HorizontalAlignment="Left" HorizontalContentAlignment="Center">
                    <ComboBoxItem Content="Arad"/>
                    <ComboBoxItem Content="Radna"/>
                </ComboBox>

                <!-- 4. TIME -->
                <TextBlock Text="4. Select approximate departure time from start station." FontSize="15" Foreground="#000000" Margin="0,0,0,8" FontWeight="Bold"/>
                <StackPanel Orientation="Horizontal" Spacing="8" Margin="0,0,0,18" HorizontalAlignment="Left">
                    <TextBox x:Name="HoursInput"
                             Classes="NumericInput"
                             Height="32" Width="50" Padding="0" FontSize="14"
                             PlaceholderText="HH" MaxLength="2"
                             TextInput="OnHoursTextInput"
                             HorizontalAlignment="Center"/>
                    <TextBlock Text=":" FontSize="18" VerticalAlignment="Center" Foreground="#000000" Margin="0,0"/>
                    <TextBox x:Name="MinutesInput"
                             Classes="NumericInput"
                             Height="32" Width="50" Padding="0" FontSize="14"
                             PlaceholderText="MM" MaxLength="2"
                             TextInput="OnMinutesTextInput"
                             HorizontalAlignment="Center"/>
                </StackPanel>

                <!-- 5. INTERMEDIATE STATIONS -->
                <TextBlock Text="5. Select how many minutes you will stop at intermediate stations. Specify the value in minutes." FontSize="15" Foreground="#000000" Margin="0,0,0,12" FontWeight="Bold"/>
                <StackPanel x:Name="IntermediatePanel" Spacing="10" Margin="0,0,0,15"/>

                <!-- 6. LOCOMOTIVE -->
                <TextBlock Text="6. Select the locomotive number you will play with." FontSize="15" Foreground="#000000" Margin="0,0,0,8" FontWeight="Bold"/>
                <Button Content="You can familiarize yourself with the numbers and list of available locomotives here poli-co.com"
                        FontSize="10" Foreground="#3458e1" Background="Transparent" BorderThickness="0"
                        HorizontalAlignment="Left" Margin="0,0,0,8" Click="OnLocomotiveLinkClick"/>
                <ComboBox x:Name="LocomotiveCombo" Height="40" Width="300" Margin="0,0,0,18" Padding="10,8" FontSize="14"
                          HorizontalAlignment="Left" HorizontalContentAlignment="Center">
                    <ComboBoxItem Content="CFR CALATORI 40-0295-2"/>
                    <ComboBoxItem Content="CFR CALATORI 41-0724-9"/>
                    <ComboBoxItem Content="CFR CALATORI 42-0302-2"/>
                    <ComboBoxItem Content="CFR CALATORI 40-0317-4"/>
                    <ComboBoxItem Content="CFR CALATORI 40-0901-5"/>
                    <ComboBoxItem Content="CFR CALATORI 40-0544-3"/>
                    <ComboBoxItem Content="CFR CALATORI 40-0770-4"/>
                    <ComboBoxItem Content="CFR CALATORI 91 53 0 400482-2 RO SNTFC"/>
                    <ComboBoxItem Content="CFR CALATORI 91 53 0 410209-7 RO SNTFC"/>
                    <ComboBoxItem Content="CFR CALATORI 91 53 0 400919-3 RO SNTFC"/>
                    <ComboBoxItem Content="CFR CALATORI 91 53 0 400540-7 RO SNTFC"/>
                    <ComboBoxItem Content="CFR CALATORI 91 53 0 410896-1 RO SNTFC"/>
                    <ComboBoxItem Content="CFR CALATORI 91 53 0 410 819-3 RO SNTFC"/>
                    <ComboBoxItem Content="CFR CALATORI 91 53 0 400565-4 RO SNTFC"/>
                    <ComboBoxItem Content="CFR MARFA 40-0788-6"/>
                    <ComboBoxItem Content="CFR MARFA 40-0914-8"/>
                    <ComboBoxItem Content="CFR MARFA 40-0524-5"/>
                    <ComboBoxItem Content="CFR MARFA 40-0489-1"/>
                    <ComboBoxItem Content="CFR MARFA 91 53 0 400533-2"/>
                    <ComboBoxItem Content="CFR MARFA 91 53 0 400439-2"/>
                </ComboBox>

                <!-- 7. WAGON COUNT -->
                <TextBlock Text="7. Select the number of wagons your train will have." FontSize="15" Foreground="#000000" Margin="0,0,0,8" FontWeight="Bold"/>
                <StackPanel Orientation="Horizontal" Spacing="8" Margin="0,0,0,18" HorizontalAlignment="Left">
                    <Button x:Name="WagonDecreaseBtn" Width="36" Height="32" Click="OnWagonDecreaseClick"
                            Background="#EEEEEE" BorderThickness="1" BorderBrush="#CCCCCC"
                            CornerRadius="4" Padding="0" FontSize="18"
                            HorizontalContentAlignment="Center" VerticalContentAlignment="Center">-</Button>
                    <TextBox x:Name="WagonCountDisplay"
                             Classes="NumericInput"
                             Height="32" Width="50" Padding="0" FontSize="14"
                             IsReadOnly="True" Text="0" HorizontalAlignment="Left"/>
                    <Button x:Name="WagonIncreaseBtn" Width="36" Height="32" Click="OnWagonIncreaseClick"
                            Background="#EEEEEE" BorderThickness="1" BorderBrush="#CCCCCC"
                            CornerRadius="4" Padding="0" FontSize="18"
                            HorizontalContentAlignment="Center" VerticalContentAlignment="Center">+</Button>
                </StackPanel>

                <!-- 8. WAGONS -->
                <TextBlock Text="8. Select the numbers of each of your wagons." FontSize="15" Foreground="#000000" Margin="0,0,0,8" FontWeight="Bold"/>
                <Button Content="You can familiarize yourself with the numbers and list of available wagons here poli-co.com"
                        FontSize="10" Foreground="#3458e1" Background="Transparent" BorderThickness="0"
                        HorizontalAlignment="Left" Margin="0,0,0,10" Click="OnWagonLinkClick"/>
                <StackPanel x:Name="WagonsPanel" Spacing="10" Margin="0,0,0,15"/>

                <!-- ADDITIONAL OPTIONS -->
                <TextBlock Text="Additional settings:" FontSize="15" Foreground="#000000" Margin="0,0,0,12" FontWeight="Bold"/>
                <StackPanel Spacing="8" Margin="0,0,0,20">
                    <RadioButton x:Name="VoiceAvailable" Content="I am available in voice (coming soon)" GroupName="Communication" FontSize="14" Foreground="#000000"/>
                    <RadioButton x:Name="TextChat" Content="I speak in text chat" GroupName="Communication" FontSize="14" Foreground="#000000" IsChecked="True"/>
                    <RadioButton x:Name="SpeakEverywhere" Content="I speak everywhere" GroupName="Communication" FontSize="14" Foreground="#000000"/>
                    <RadioButton x:Name="NoCommunication" Content="I don't speak anywhere at all" GroupName="Communication" FontSize="14" Foreground="#000000"/>
                </StackPanel>

                <!-- BUTTON -->
                <Button Height="40" Padding="30,0" Background="#3458e1" BorderThickness="0" CornerRadius="8"
                        HorizontalContentAlignment="Center" VerticalContentAlignment="Center"
                        Margin="0,0,0,10" Click="OnSaveAndConnectClick">
                    <TextBlock Text="Save and Send to PC|MP" Foreground="White" FontSize="13" FontWeight="Bold"/>
                </Button>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</UserControl>
